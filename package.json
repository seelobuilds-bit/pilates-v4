{
  "name": "pilates-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm demo:sync && next dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:security:rls:all": "bash scripts/security/apply-rls-public-all.sh",
    "media:migrate:dry": "node scripts/migrate-blob-to-supabase.mjs",
    "media:migrate:apply": "node scripts/migrate-blob-to-supabase.mjs --apply",
    "typecheck": "tsc --noEmit",
    "test:authz": "node scripts/tests/authz-boundaries.mjs",
