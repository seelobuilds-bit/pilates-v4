    "test:baseline:reporting": "node scripts/tests/reporting-baseline-capture.mjs",
    "test:baseline:reporting:compare": "node scripts/tests/reporting-baseline-compare.mjs",
    "test:employees:timeoff": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/employees-timeoff-logic.ts",
