    "test:integration": "pnpm test:authz && pnpm test:booking && pnpm test:smoke && pnpm test:smoke:reporting",
    "build": "pnpm demo:sync && prisma generate && next build",
    "demo:sync": "node scripts/sync-demo-mirrors.mjs",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "test:reporting:date-range": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-date-range-logic.ts",
    "test:reporting:monthly": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-monthly-logic.ts",
