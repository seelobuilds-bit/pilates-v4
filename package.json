    "test:smoke": "node scripts/tests/smoke-routes.mjs",
    "test:smoke:owner": "node scripts/tests/owner-flow-smoke.mjs",
    "test:smoke:mobile": "node scripts/tests/mobile-api-smoke.mjs",
    "test:smoke:mobile:auth-routing": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/mobile-auth-routing-smoke.ts",
    "test:smoke:mobile:routing": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/mobile-push-routing-smoke.ts",
    "test:smoke:studio-content": "node scripts/tests/studio-content-surface-smoke.mjs",
