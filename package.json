    "test:reporting:client-activity": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-client-activity-logic.ts",
    "test:reporting:instructors": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-instructors-logic.ts",
    "test:reporting:teacher-performance": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-teacher-performance-logic.ts",
    "test:reporting:teacher-entity": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-teacher-entity-logic.ts",
    "test:reporting:marketing": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-marketing-logic.ts",
    "test:reporting:social": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-social-logic.ts",
    "test:reporting:fallback": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-fallback-logic.ts",
    "test:leaderboards:presentation": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/leaderboard-presentation-logic.ts",
    "test:leaderboards:score": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/leaderboard-score-logic.ts",
    "test:vault:analytics": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/vault-analytics-logic.ts",
    "test:class-flows:analytics": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/class-flow-analytics-logic.ts",
    "test:website-marketing:analytics": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/website-marketing-analytics-logic.ts"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
