    "test:reporting:attendance": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-attendance-logic.ts",
    "test:reporting:classes": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-classes-logic.ts",
    "test:reporting:class-type-entity": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/tests/reporting-class-type-entity-logic.ts",
